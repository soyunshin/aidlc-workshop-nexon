# Database
DATABASE_URL=mysql+asyncmy://app_user:app_password@localhost:3306/table_order

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=16

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Application
DEBUG=True
APP_NAME=TableOrder
APP_VERSION=0.1.0
